include(conan-profile-common)

[settings]
os=Windows
arch=armv8
compiler=msvc
compiler.version=194
compiler.cppstd={{ os.getenv("CXX_VERSION") }}
compiler.runtime=dynamic
doxygen/*:compiler.cppstd=17
strawberryperl/*:arch=x86_64

[conf]
tools.build:cxxflags=["/openmp", "/MP", "/DEBUG:NONE", "/O2"]
tools.build:cflags=["/openmp", "/MP", "/DEBUG:NONE", "/O2"]
# Keep the user toolchain connection so Embree pairs with its architectural parameters
embree/*:tools.cmake.cmaketoolchain:user_toolchain+={{os.getenv("LUX_PROFILE_DIR", profile_dir)}}/windows-vars-ARM64.cmake

# Following deps are to be compiled with msys2/gcc: MSVC flags will not do
libiconv/*:tools.build:cxxflags=!
libiconv/*:tools.build:cflags=!

[options]
embree/*:shared=True
onetbb/*:tbbproxy=False
xapian-core/*:build=False

